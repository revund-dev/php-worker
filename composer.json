{
  "name": "revund/php-worker",
  "description": "Revund's PHP AST sidecar — implements the universal revund.worker.v1.Worker gRPC contract using nikic/PHP-Parser.",
  "type": "library",
  "license": "Apache-2.0",
  "homepage": "https://revund.dev",
  "support": {
    "issues": "https://github.com/revund-dev/php-worker/issues",
    "source": "https://github.com/revund-dev/php-worker"
  },
  "keywords": [
    "revund",
    "ast",
    "code-review",
    "grpc",
    "sidecar",
    "php-parser"
  ],
  "require": {
    "php": ">=8.1",
    "nikic/php-parser": "^5.0",
    "grpc/grpc": "^1.57",
    "google/protobuf": "^3.25"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Revund\\PHPWorker\\": "src/"
    },
    "files": [
      "proto/Revund/Worker/V1/Worker.php",
      "proto/GPBMetadata/Worker.php"
    ]
  },
  "bin": ["bin/revund-php-worker"],
  "config": {
    "sort-packages": true
  },
  "scripts": {
    "vendor-proto": "@php -r \"@mkdir('proto', 0777, true); if (!@copy('../../proto/worker/v1/worker.proto', 'proto/worker.proto')) { fwrite(STDERR, \\\"vendor-proto: ../../proto/worker/v1/worker.proto not found (skipped — using existing proto/worker.proto if present)\\n\\\"); }\"",
    "proto": [
      "@vendor-proto",
      "protoc --proto_path=proto --php_out=proto --grpc_out=proto --plugin=protoc-gen-grpc=$(which grpc_php_plugin) proto/worker.proto"
    ],
    "start": "php bin/revund-php-worker"
  }
}
